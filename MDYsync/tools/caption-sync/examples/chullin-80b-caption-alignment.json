  "segments": [
    {
      "ref": "Chullin 80b:5",
      "start": 7.87,
      "end": 21.96,
      "he": "פְּשִׁיטָא דְּהָכִי אִיתַהּ? שְׁחִיטַת קָדָשִׁים אִיצְטְרִיכָא לֵיהּ, סָלְקָא דַּעְתָּךְ אָמֵינָא: שְׁחִיטַת קָדָשִׁים שְׁחִיטָה רְאוּיָה הִיא, דְּהָא אִי נָחַר וְזָרֵיק דָּם – לָא מִישְׁתְּרֵי בָּשָׂר, וְכִי שָׁחַט – מִישְׁתְּרֵי בָּשָׂר, וּשְׁחִיטָה רְאוּיָה הִיא; קָא מַשְׁמַע לַן."
    },
    {
      "ref": "Chullin 80b:6",
      "start": 1.31,
      "end": 38.67,
      "he": "וְלִילְקֵי נָמֵי מִשּׁוּם לָאו דִּמְחוּסַּר זְמַן, דְּתַנְיָא: מִנַּיִן לְכׇל הַפְּסוּלִין שֶׁבַּשּׁוֹר וְשֶׁבַּשֶּׂה שֶׁהוּא בְּ״לֹא יֵרָצֶה״?"
    },
    {
      "ref": "Chullin 80b:7",
      "start": 38.67,
      "end": 44.9,
      "he": "תַּלְמוּד לוֹמַר: ״וְשׁוֹר וָשֶׂה שָׂרוּעַ וְקָלוּט וְגוֹ׳״, לִימֵּד עַל הַפְּסוּלִין שֶׁבַּשּׁוֹר וְשֶׁבַּשֶּׂה, שֶׁהוּא בְּ״לֹא יֵרָצֶה״!"
    },
    {
      "ref": "Chullin 80b:8",
      "start": 44.9,
      "end": 65.88,
      "he": "כִּי קָא חָשֵׁיב לָאוֵי דְּ״אוֹתוֹ וְאֶת בְּנוֹ״ – לָאוֵי נוּכְרָאֵי לָא קָא חָשֵׁיב."
    },
    {
      "ref": "Chullin 80b:9",
      "start": 60.96,
      "end": 117.0,
      "he": "וְלָא? וְהָא קָדָשִׁים בַּחוּץ, דְּלָאוֵי נוּכְרָאֵי נִינְהוּ, וְקָא חָשֵׁיב, דְּקָתָנֵי: קָדָשִׁים בַּחוּץ – הָרִאשׁוֹן חַיָּיב כָּרֵת, וּשְׁנֵיהֶם סוֹפְגִין אֶת הָאַרְבָּעִים."
    },
    {
      "ref": "Chullin 80b:10",
      "start": 91.44,
      "end": 126.51,
      "he": "בִּשְׁלָמָא שֵׁנִי, מִשּׁוּם לָאו דְּ״אוֹתוֹ וְאֶת בְּנוֹ״, אֶלָּא רִאשׁוֹן אַמַּאי סוֹפֵג? לָאו מִשּׁוּם לָאו דִּשְׁחוּטֵי חוּץ?"
    },
    {
      "ref": "Chullin 80b:11",
      "start": 126.51,
      "end": 141.81,
      "he": "כֹּל הֵיכָא דְּלֵיכָּא לָאו דְּ״אוֹתוֹ וְאֶת בְּנוֹ״ – חָשֵׁיב לָאוֵי נוּכְרָאֵי, וְכֹל הֵיכָא דְּאִיכָּא לָאו דְּ״אוֹתוֹ וְאֶת בְּנוֹ״ – לָא חָשֵׁיב לָאוֵי נוּכְרָאֵי."
    }
  ],
